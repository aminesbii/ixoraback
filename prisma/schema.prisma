generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  full_name    String   @db.VarChar(100)
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(CUSTOMER)
  status       Status   @default(ACTIVE)
  permissions  String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  carts         Cart[]
  orders        Order[]
  addresses     Address[]
  productEvents ProductEvent[]
}

enum Role {
  ADMIN
  CUSTOMER
  MANAGER
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Category {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique
  parent_id  String?  @db.Uuid
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   Category?  @relation("ParentCategory", fields: [parent_id], references: [id])
  children Category[] @relation("ParentCategory")
  products Product[]

  @@index([parent_id, sort_order])
}

model Product {
  id                String   @id @default(uuid()) @db.Uuid
  category_id       String?  @db.Uuid
  name              String   @db.VarChar(200)
  slug              String   @unique
  short_description String?  @db.VarChar(500)
  description       String?
  details           Json?    @default("{}")
  status            ProductStatus @default(DRAFT)
  is_featured       Boolean  @default(false)
  on_sale           Boolean  @default(false)
  sale_percentage   Int?
  base_price        Float?
  currency          String   @default("TND") @db.VarChar(3)
  clicks            Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category                Category?                 @relation(fields: [category_id], references: [id])
  variants                ProductVariant[]
  images                  ProductImage[]
  cartItems               CartItem[]
  orderItems              OrderItem[]
  productEvents           ProductEvent[]
  productPerformanceDaily ProductPerformanceDaily[]

  @@index([category_id, status])
  @@index([is_featured, status])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductVariant {
  id               String   @id @default(uuid()) @db.Uuid
  product_id       String   @db.Uuid
  sku              String   @unique
  variant_name     String?  @db.VarChar(150)
  price            Float
  compare_at_price Float?
  currency         String   @default("MAD") @db.VarChar(3)
  stock_qty        Int      @default(0)
  is_active        Boolean  @default(true)
  image_url        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product    Product     @relation(fields: [product_id], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([product_id, is_active])
}

model ProductImage {
  id         String   @id @default(uuid()) @db.Uuid
  product_id String   @db.Uuid
  image_url  String
  alt_text   String?  @db.VarChar(200)
  sort_order Int      @default(0)
  is_main    Boolean  @default(false)
  featured1  Boolean  @default(false)
  featured2  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id])

  @@index([product_id, is_main])
  @@index([product_id, sort_order])
  @@index([product_id, featured1])
  @@index([product_id, featured2])
}

model Cart {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid
  session_token String?
  status        CartStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User?      @relation(fields: [user_id], references: [id])
  cartItems CartItem[]

  @@index([user_id, status])
  @@index([session_token, status])
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

model CartItem {
  id         String   @id @default(uuid()) @db.Uuid
  cart_id    String   @db.Uuid
  product_id String   @db.Uuid
  variant_id String?  @db.Uuid
  quantity   Int
  unit_price Float
  added_at   DateTime @default(now())

  cart    Cart            @relation(fields: [cart_id], references: [id])
  product Product         @relation(fields: [product_id], references: [id])
  variant ProductVariant? @relation(fields: [variant_id], references: [id])

  @@unique([cart_id, product_id, variant_id])
}

model Order {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String?  @db.Uuid
  session_token  String?
  order_number   String   @unique
  customer_name  String
  customer_email String
  customer_phone String?
  status         OrderStatus @default(PENDING)
  subtotal       Float
  discount_total Float    @default(0)
  shipping_fee   Float    @default(0)
  tax_total      Float    @default(0)
  grand_total    Float
  currency       String   @default("MAD") @db.VarChar(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User?       @relation(fields: [user_id], references: [id])
  orderItems OrderItem[]
  addresses  Address[]

  @@index([user_id, status])
  @@index([session_token])
  @@index([customer_email])
  @@index([createdAt(sort: Desc)])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id                    String   @id @default(uuid()) @db.Uuid
  order_id              String   @db.Uuid
  product_id            String   @db.Uuid
  variant_id            String?  @db.Uuid
  product_name_snapshot String
  sku_snapshot          String?
  unit_price_snapshot   Float
  quantity              Int
  line_total            Float

  order   Order           @relation(fields: [order_id], references: [id])
  product Product         @relation(fields: [product_id], references: [id])
  variant ProductVariant? @relation(fields: [variant_id], references: [id])

  @@index([order_id])
  @@index([product_id])
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String?  @db.Uuid
  order_id    String?  @db.Uuid
  type        AddressType
  full_name   String   @db.VarChar(100)
  phone       String?
  street      String   @db.VarChar(200)
  city        String   @db.VarChar(100)
  postal_code String?  @db.VarChar(20)
  country     String   @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User?  @relation(fields: [user_id], references: [id])
  order Order? @relation(fields: [order_id], references: [id])

  @@index([user_id, type])
  @@index([order_id, type])
}

enum AddressType {
  BILLING
  SHIPPING
}

model ProductEvent {
  id            String   @id @default(uuid()) @db.Uuid
  product_id    String   @db.Uuid
  user_id       String?  @db.Uuid
  session_token String?
  event_type    EventType
  created_at    DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id])
  user    User?   @relation(fields: [user_id], references: [id])

  @@index([product_id, event_type, created_at(sort: Desc)])
  @@index([session_token, created_at(sort: Desc)])
}

enum EventType {
  VIEW         @map("view")
  CLICK        @map("click")
  ADD_TO_CART  @map("add_to_cart")
  PURCHASE     @map("purchase")
}

model ProductPerformanceDaily {
  id                String   @id @default(uuid()) @db.Uuid
  product_id        String   @db.Uuid
  date              DateTime
  click_count       Int      @default(0)
  add_to_cart_count Int      @default(0)
  purchase_count    Int      @default(0)
  revenue_generated Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id])

  @@unique([product_id, date])
  @@index([date(sort: Desc)])
}
